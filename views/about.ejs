<section class="about-section">
  <div class="container">
    <h1 class="page-title">About Me</h1>
    <div class="about-content">
      <div class="about-image">
        <img src="/images/shivam_new.jpg" alt="Shivam">
      </div>
      <div class="about-text">
        <h2><%= settings.aboutTitle %></h2>
        <p>
          <%= settings.aboutDescription %>
        </p>
        <h3>What I Do</h3>
        <ul class="about-list">
          <% if (settings.whatIDo && settings.whatIDo.length > 0) { %>
            <% settings.whatIDo.forEach(item => { %>
              <li><i class="fas fa-check"></i> <%= item.text %></li>
            <% }) %>
          <% } else { %>
            <li><i class="fas fa-check"></i> Build responsive and interactive web applications</li>
            <li><i class="fas fa-check"></i> Develop RESTful APIs and microservices</li>
            <li><i class="fas fa-check"></i> Design and implement database solutions</li>
            <li><i class="fas fa-check"></i> Create clean, efficient, and well-documented code</li>
            <li><i class="fas fa-check"></i> Collaborate with teams to deliver projects on time</li>
          <% } %>
        </ul>
      </div>
    </div>
  </div>
</section>
